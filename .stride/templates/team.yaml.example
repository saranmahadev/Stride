# Example team.yaml schema structure
# This file demonstrates the structure for .stride/team.yaml

schema_version: "1.5"
project_name: "Example Project"
created_at: "2025-01-15T10:30:00Z"

members:
  - username: "alice"
    email: "alice@example.com"
    role: "admin"
    joined_at: "2025-01-15T10:30:00Z"
    active: true
    
  - username: "bob"
    email: "bob@example.com"
    role: "developer"
    joined_at: "2025-01-15T10:35:00Z"
    active: true

roles:
  admin:
    - manage_team
    - assign_sprints
    - approve_sprints
    - complete_sprints
  developer:
    - assign_sprints
    - complete_sprints
  reviewer:
    - approve_sprints
    - comment
  viewer:
    - view_only

approval_policy:
  required_approvers: 2
  allow_self_approval: false
  block_completion: true
